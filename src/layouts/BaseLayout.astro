---
import '@styles/global.css'
import '@fontsource-variable/plus-jakarta-sans'
import '@fontsource/reenie-beanie'
import { Nav } from '@components/nav/Nav'
import Footer from '@components/Footer.astro'
import { ViewTransitions } from 'astro:transitions'

const { pageTitle } = Astro.props
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>
        <link
            rel="preload"
            href="https://cdn.jsdelivr.net/fontsource/fonts/reenie-beanie@latest/latin-400-normal.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href="https://cdn.jsdelivr.net/fontsource/fonts/plus-jakarta-sans:vf@latest/latin-wght-normal.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <ViewTransitions />
        <link
            rel="icon"
            type="image/png"
            href="/favicon-48x48.png"
            sizes="48x48"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <meta name="apple-mobile-web-app-title" content="steelesh" />
        <link rel="manifest" href="/site.webmanifest" />
        <script src="./../util/copyCodeButtonHandler.js"></script>
    </head>
    <body>
        <div id="content">
            <Nav client:only="react" />
            <main>
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>
